module number_theory:
  capability gcd:
    input: Int a, Int b
    output: Int
    intent: compute gcd using euclidean algorithm

  capability power:
    input: Int base, Int exp
    output: Int
    intent: compute power/exponent

  capability factorial:
    input: Int n
    output: Int
    intent: compute factorial using recursion

  capability fibonacci:
    input: Int n
    output: Int
    intent: compute nth fibonacci number
